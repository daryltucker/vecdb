{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Unified Artifact Schema",
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "enum": [
                "TEST_RESULT",
                "BUILD_ERROR",
                "LINT_ERROR",
                "SECURITY_VULNERABILITY",
                "COMPILATION_WARNING"
            ],
            "description": "Type of the artifact"
        },
        "source": {
            "type": "string",
            "description": "Tool that generated this artifact (e.g., cargo, pytest, eslint)"
        },
        "status": {
            "type": "string",
            "enum": [
                "SUCCESS",
                "FAILURE",
                "WARNING",
                "SKIPPED"
            ],
            "description": "Outcome status"
        },
        "summary": {
            "type": "string",
            "description": "Short summary of the finding"
        },
        "details": {
            "type": "string",
            "description": "Detailed explanation or stack trace"
        },
        "location": {
            "type": "object",
            "properties": {
                "file": {
                    "type": "string"
                },
                "line": {
                    "type": "integer"
                },
                "column": {
                    "type": "integer"
                },
                "end_line": {
                    "type": "integer"
                },
                "end_column": {
                    "type": "integer"
                }
            }
        },
        "check_name": {
            "type": "string",
            "description": "Specific check or rule ID usage (e.g., E501, clippy::complexity)"
        }
    },
    "required": [
        "type",
        "status"
    ],
    "additionalProperties": true
}