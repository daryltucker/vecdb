{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Unified Log Schema",
    "type": "object",
    "properties": {
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp"
        },
        "level": {
            "type": "string",
            "enum": [
                "DEBUG",
                "INFO",
                "WARN",
                "ERROR",
                "FATAL"
            ],
            "description": "Log severity level"
        },
        "message": {
            "type": "string",
            "description": "Main log message"
        },
        "source": {
            "type": "string",
            "description": "Origin of the log (service name, app name, etc.)"
        },
        "data": {
            "type": "object",
            "description": "Structured data associated with the log entry",
            "additionalProperties": true
        },
        "trace_id": {
            "type": "string",
            "description": "Trace ID for distributed tracing"
        },
        "span_id": {
            "type": "string",
            "description": "Span ID for distributed tracing"
        }
    },
    "required": [
        "timestamp",
        "level",
        "message"
    ],
    "additionalProperties": true
}